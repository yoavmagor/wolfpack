#!/usr/bin/env bash
set -euo pipefail

# claude-bridge-setup — One-time setup for the WhatsApp ↔ tmux bridge.
#
# What it does:
#   1. Adds selfChatMode: true to WhatsApp config in clawdbot.json
#   2. Restarts the gateway (loads the plugin)
#   3. Launches WhatsApp QR login (you scan with your phone)

CONFIG="$HOME/.clawdbot/clawdbot.json"
BOLD='\033[1m'
DIM='\033[2m'
GREEN='\033[32m'
YELLOW='\033[33m'
RED='\033[31m'
RESET='\033[0m'

info()  { printf "${GREEN}▸${RESET} %s\n" "$*"; }
warn()  { printf "${YELLOW}▸${RESET} %s\n" "$*"; }
err()   { printf "${RED}✗${RESET} %s\n" "$*" >&2; }
step()  { printf "\n${BOLD}── %s${RESET}\n" "$*"; }

# ── Preflight ────────────────────────────────────────────────────────────────
if ! command -v clawdbot &>/dev/null; then
  err "clawdbot CLI not found in PATH"
  exit 1
fi

if ! command -v tmux &>/dev/null; then
  err "tmux not found. Install it: brew install tmux"
  exit 1
fi

if ! command -v jq &>/dev/null; then
  err "jq not found. Install it: brew install jq"
  exit 1
fi

if [[ ! -f "$CONFIG" ]]; then
  err "clawdbot.json not found at $CONFIG"
  err "Run 'clawdbot setup' first."
  exit 1
fi

# ── Step 1: Add selfChatMode to WhatsApp config ─────────────────────────────
step "1/3 — Configuring WhatsApp selfChatMode"

if jq -e '.channels.whatsapp.selfChatMode == true' "$CONFIG" &>/dev/null; then
  info "selfChatMode already enabled"
else
  # Back up config
  cp "$CONFIG" "$CONFIG.bak.$(date +%s)"

  # Add selfChatMode: true to channels.whatsapp
  jq '.channels.whatsapp.selfChatMode = true' "$CONFIG" > "$CONFIG.tmp" \
    && mv "$CONFIG.tmp" "$CONFIG"
  info "Added selfChatMode: true to channels.whatsapp"
fi

# Also ensure group policy allows groups (wildcard already present in most configs)
if jq -e '.channels.whatsapp.groupPolicy' "$CONFIG" &>/dev/null; then
  policy=$(jq -r '.channels.whatsapp.groupPolicy' "$CONFIG")
  if [[ "$policy" == "allowlist" ]]; then
    warn "groupPolicy is 'allowlist' — your bridge groups need to be in the allowlist"
    warn "Or change to 'all' if you only use solo groups:"
    warn "  jq '.channels.whatsapp.groupPolicy = \"all\"' $CONFIG | sponge $CONFIG"
  fi
fi

# ── Step 2: Restart gateway ──────────────────────────────────────────────────
step "2/3 — Restarting gateway"

if pgrep -f "clawdbot.*gateway" &>/dev/null; then
  info "Gateway is running, restarting with --force"
  nohup clawdbot gateway --force --port 18789 > /tmp/clawdbot-bridge-setup.log 2>&1 &
  GATEWAY_PID=$!
  sleep 4

  if kill -0 "$GATEWAY_PID" 2>/dev/null; then
    info "Gateway started (PID $GATEWAY_PID)"
  else
    err "Gateway failed to start. Check /tmp/clawdbot-bridge-setup.log"
    exit 1
  fi
else
  info "Starting gateway"
  nohup clawdbot gateway --port 18789 > /tmp/clawdbot-bridge-setup.log 2>&1 &
  GATEWAY_PID=$!
  sleep 4

  if kill -0 "$GATEWAY_PID" 2>/dev/null; then
    info "Gateway started (PID $GATEWAY_PID)"
  else
    err "Gateway failed to start. Check /tmp/clawdbot-bridge-setup.log"
    exit 1
  fi
fi

# Verify plugin loaded
if grep -q "claude-bridge plugin loaded" /tmp/clawdbot-bridge-setup.log 2>/dev/null; then
  info "claude-bridge plugin loaded successfully"
else
  warn "Could not verify plugin loaded — check: grep 'claude-bridge' /tmp/clawdbot-bridge-setup.log"
fi

# ── Step 3: WhatsApp QR login ────────────────────────────────────────────────
step "3/3 — WhatsApp login"

# Check if already linked
STATUS=$(clawdbot channels status 2>&1 || true)
if echo "$STATUS" | grep -q "whatsapp.*running"; then
  info "WhatsApp already linked and running"
else
  warn "WhatsApp is not linked. Starting QR login..."
  warn "Scan the QR code with your phone (WhatsApp > Linked Devices > Link a Device)"
  echo ""
  clawdbot channels login --verbose
fi

# ── Done ─────────────────────────────────────────────────────────────────────
step "Setup complete"
echo ""
info "Next steps:"
echo "  1. Create a solo WhatsApp group on your phone (just you)"
echo "  2. Name it after your project (e.g., \"my-project\")"
echo "  3. Run: claude-bridge-new my-project ~/Dev/my-project"
echo "  4. Send any message in the WhatsApp group to start bridging"
echo ""
