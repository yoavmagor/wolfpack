#!/usr/bin/env bash
set -euo pipefail

# claude-bridge-new — Create a new tmux session with Claude Code for bridging.
#
# Usage:
#   claude-bridge-new <name> [directory]
#
# Examples:
#   claude-bridge-new my-project ~/Dev/my-project
#   claude-bridge-new playground               # uses current directory

BOLD='\033[1m'
DIM='\033[2m'
GREEN='\033[32m'
YELLOW='\033[33m'
RED='\033[31m'
RESET='\033[0m'

info()  { printf "${GREEN}▸${RESET} %s\n" "$*"; }
warn()  { printf "${YELLOW}▸${RESET} %s\n" "$*"; }
err()   { printf "${RED}✗${RESET} %s\n" "$*" >&2; }

usage() {
  echo "Usage: claude-bridge-new <session-name> [project-directory]"
  echo ""
  echo "Creates a tmux session running Claude Code for WhatsApp bridging."
  echo ""
  echo "Arguments:"
  echo "  session-name       Name for the tmux session (should match WhatsApp group name)"
  echo "  project-directory  Working directory (default: current directory)"
  echo ""
  echo "Examples:"
  echo "  claude-bridge-new my-project ~/Dev/my-project"
  echo "  claude-bridge-new playground"
  exit 1
}

if [[ $# -lt 1 ]]; then
  usage
fi

SESSION_NAME="$1"
PROJECT_DIR="${2:-$(pwd)}"

# Resolve to absolute path
PROJECT_DIR="$(cd "$PROJECT_DIR" 2>/dev/null && pwd)" || {
  err "Directory does not exist: $2"
  exit 1
}

# ── Preflight ────────────────────────────────────────────────────────────────
if ! command -v tmux &>/dev/null; then
  err "tmux not found. Install it: brew install tmux"
  exit 1
fi

if ! command -v claude &>/dev/null; then
  err "claude CLI not found in PATH"
  exit 1
fi

CLAWDBOT_DIR="${HOME}/.clawdbot"
TOKEN_FILE="${CLAWDBOT_DIR}/claude-bridge-tokens.json"
TOKEN_TTL=300  # 5 minutes

# ── Check for existing session ───────────────────────────────────────────────
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  warn "tmux session '$SESSION_NAME' already exists"
  info "Attach with: tmux attach -t $SESSION_NAME"
  info "Or kill and recreate: tmux kill-session -t $SESSION_NAME"
  exit 0
fi

# ── Create tmux session ─────────────────────────────────────────────────────
info "Creating tmux session '$SESSION_NAME' in $PROJECT_DIR"
tmux new-session -d -s "$SESSION_NAME" -c "$PROJECT_DIR"

# Start Claude Code in bridge mode
BRIDGE_PROMPT="You are being controlled via a WhatsApp bridge. Rules: Keep ALL responses concise (1-3 sentences) unless the user says elaborate or expand. NEVER use interactive prompts, multiple-choice questions, or ask the user to select options. When using tools, summarize the result in 1-2 sentences. Do not dump raw file contents or command output. If you need clarification, ask a single short question. Do not use markdown formatting. Plain text only."

info "Starting Claude Code (bridge mode)"
tmux send-keys -t "$SESSION_NAME" "claude --dangerously-skip-permissions --append-system-prompt \"$BRIDGE_PROMPT\"" Enter

# ── Generate activation token ────────────────────────────────────────────────
TOKEN=$(openssl rand -hex 16)
NOW=$(date +%s)
EXPIRES=$((NOW + TOKEN_TTL))

# Ensure token file exists with valid JSON
if [[ ! -f "$TOKEN_FILE" ]]; then
  echo '{"tokens":{}}' > "$TOKEN_FILE"
fi

# Add token using a temp file for atomic write
TMPFILE=$(mktemp)
python3 -c "
import json, sys
with open('$TOKEN_FILE') as f:
    data = json.load(f)
data['tokens']['$TOKEN'] = {
    'tmuxSession': '$SESSION_NAME',
    'createdAt': $NOW,
    'expiresAt': $EXPIRES
}
json.dump(data, sys.stdout, indent=2)
" > "$TMPFILE" && mv "$TMPFILE" "$TOKEN_FILE"

# ── Done ─────────────────────────────────────────────────────────────────────
echo ""
info "Session '$SESSION_NAME' is ready"
echo ""
echo "  Attach:  tmux attach -t $SESSION_NAME"
echo "  Kill:    tmux kill-session -t $SESSION_NAME"
echo ""
echo "  Activation token: $TOKEN"
echo "  Expires in ${TOKEN_TTL}s"
echo ""
echo "  Create a WhatsApp solo group named 'cc-${SESSION_NAME}',"
echo "  then send: !activate $TOKEN"
echo ""
