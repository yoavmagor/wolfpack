#!/usr/bin/env bash
set -euo pipefail

# claude-bridge-new — Create a new tmux session with Claude Code for bridging.
#
# Usage:
#   claude-bridge-new <name> [directory]
#
# Examples:
#   claude-bridge-new my-project ~/Dev/my-project
#   claude-bridge-new playground               # uses current directory

BOLD='\033[1m'
DIM='\033[2m'
GREEN='\033[32m'
YELLOW='\033[33m'
RED='\033[31m'
RESET='\033[0m'

info()  { printf "${GREEN}▸${RESET} %s\n" "$*"; }
warn()  { printf "${YELLOW}▸${RESET} %s\n" "$*"; }
err()   { printf "${RED}✗${RESET} %s\n" "$*" >&2; }

usage() {
  echo "Usage: claude-bridge-new <session-name> [project-directory]"
  echo ""
  echo "Creates a tmux session running Claude Code for WhatsApp bridging."
  echo ""
  echo "Arguments:"
  echo "  session-name       Name for the tmux session (should match WhatsApp group name)"
  echo "  project-directory  Working directory (default: current directory)"
  echo ""
  echo "Examples:"
  echo "  claude-bridge-new my-project ~/Dev/my-project"
  echo "  claude-bridge-new playground"
  exit 1
}

if [[ $# -lt 1 ]]; then
  usage
fi

SESSION_NAME="$1"
PROJECT_DIR="${2:-$(pwd)}"

# Resolve to absolute path
PROJECT_DIR="$(cd "$PROJECT_DIR" 2>/dev/null && pwd)" || {
  err "Directory does not exist: $2"
  exit 1
}

# ── Preflight ────────────────────────────────────────────────────────────────
if ! command -v tmux &>/dev/null; then
  err "tmux not found. Install it: brew install tmux"
  exit 1
fi

if ! command -v claude &>/dev/null; then
  err "claude CLI not found in PATH"
  exit 1
fi

# ── Check for existing session ───────────────────────────────────────────────
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
  warn "tmux session '$SESSION_NAME' already exists"
  info "Attach with: tmux attach -t $SESSION_NAME"
  info "Or kill and recreate: tmux kill-session -t $SESSION_NAME"
  exit 0
fi

# ── Create tmux session ─────────────────────────────────────────────────────
info "Creating tmux session '$SESSION_NAME' in $PROJECT_DIR"
tmux new-session -d -s "$SESSION_NAME" -c "$PROJECT_DIR"

# Start Claude Code in non-interactive mode
info "Starting Claude Code (--dangerously-skip-permissions)"
tmux send-keys -t "$SESSION_NAME" "claude --dangerously-skip-permissions" Enter

# ── Done ─────────────────────────────────────────────────────────────────────
echo ""
info "Session '$SESSION_NAME' is ready"
echo ""
echo "  Attach:  tmux attach -t $SESSION_NAME"
echo "  Kill:    tmux kill-session -t $SESSION_NAME"
echo ""
echo "  Now create a WhatsApp group named '${SESSION_NAME}' and send 'bridge' in it."
echo ""
