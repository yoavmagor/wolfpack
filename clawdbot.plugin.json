{
  "id": "claude-bridge",
  "name": "Claude Bridge",
  "description": "Bridges WhatsApp group chats to Claude Code tmux sessions",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": { "type": "boolean", "default": true },
      "outputPrefix": { "type": "string", "default": "\ud83e\udd16" },
      "quietTimeoutMs": { "type": "integer", "minimum": 200, "default": 1000 },
      "maxOutputChars": { "type": "integer", "minimum": 100, "default": 12000 }
    }
  }
}
