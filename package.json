{
  "name": "wolfpack-bridge",
  "version": "1.5.7",
  "type": "module",
  "description": "Mobile command center for tmux-based AI agent sessions",
  "bin": {
    "wolfpack": "./bin/run.cjs"
  },
  "files": [
    "bin/run.cjs",
    "bin/install.cjs"
  ],
  "scripts": {
    "test": "bun test",
    "test:e2e": "bunx playwright test",
    "test:e2e:headed": "bunx playwright test --headed",
    "postinstall": "node bin/install.cjs"
  },
  "optionalDependencies": {
    "wolfpack-bridge-darwin-arm64": "1.5.6",
    "wolfpack-bridge-darwin-x64": "1.5.6",
    "wolfpack-bridge-linux-arm64": "1.5.6",
    "wolfpack-bridge-linux-x64": "1.5.6"
  },
  "keywords": [
    "tmux",
    "ai",
    "agents",
    "mobile",
    "pwa",
    "terminal",
    "claude",
    "codex"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/almogdepaz/wolfpack"
  },
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "playwright": "^1.58.2"
  }
}
